{
  "name": "deepds-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:proxy": "pnpm --filter @deepds/proxy dev",
    "dev:web": "pnpm --filter @deepds/web dev",
    "dev:dummy:proxy": "DUMMY_MODE=true pnpm --filter @deepds/proxy dev",
    "dev:dummy:web": "NEXT_PUBLIC_DUMMY_MODE=true pnpm --filter @deepds/web dev",
    "host:local": "bash scripts/host-local.sh",
    "build": "pnpm -r build",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
